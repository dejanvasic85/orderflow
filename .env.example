VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SITE_URL=http://localhost:3344
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# AWS — when configured enables email (SES) and SMS (SNS) notifications
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SES_FROM_ADDRESS=
# Local/CI only — when AWS is unset, deliver emails to Mailpit's HTTP send API so
# notifications are visible in dev and assertable in e2e. Leave blank in production.
MAILPIT_API_URL=http://localhost:54324
# Cloudflare R2 — product image storage
# Create API token: Cloudflare dashboard → R2 → Manage R2 API tokens (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=orderflow-assets
R2_PUBLIC_BASE_URL=
# Production smoke tests (vp run test:smoke) — logs into the real prod site as this account
SMOKE_SITE_URL=https://bwow.app
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
