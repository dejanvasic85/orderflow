{
  "name": "orderflow",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3344\"",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "test:e2e": "playwright test",
    "deploy": "vp run build && vp exec wrangler deploy",
    "start": "node --import ./instrument.server.mjs dist/server/index.js",
    "prepare": "vp config",
    "db:gentypes": "supabase gen types typescript --local > src/lib/database.types.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.105.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-form": "1.29.1",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-query-devtools": "5.100.9",
    "@tanstack/react-router": "1.169.1",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-router-ssr-query": "1.166.12",
    "@tanstack/react-start": "1.167.62",
    "@tanstack/router-plugin": "1.167.32",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "supabase": "2.98.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20",
    "vite-plus": "0.1.20",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.20",
    "wrangler": "^4.70.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.20"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      }
    }
  }
}
