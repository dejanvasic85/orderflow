{
  "name": "orderflow",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3344\"",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "vp run build && vp exec wrangler deploy",
    "start": "node --import ./instrument.server.mjs dist/server/index.js",
    "prepare": "vp config",
    "db:gentypes": "supabase gen types typescript --local > src/lib/database.types.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.39.1",
    "@fontsource-variable/outfit": "5.2.8",
    "@sentry/tanstackstart-react": "10.55.0",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.106.2",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.18",
    "@tanstack/router-plugin": "1.168.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "dotenv-cli": "11.0.0",
    "framer-motion": "12.40.0",
    "lucide-react": "1.17.0",
    "playwright": "1.60.0",
    "radix-ui": "1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.10.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/devtools-vite": "0.7.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "dotenv": "17.4.2",
    "jsdom": "28.1.0",
    "supabase": "2.104.0",
    "tsx": "4.22.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vite-plus": "0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24",
    "wrangler": "4.96.0"
  },
  "packageManager": "pnpm@10.34.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "esbuild",
      "lightningcss",
      "msw",
      "sharp",
      "supabase",
      "workerd"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      }
    }
  }
}
